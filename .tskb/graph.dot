          "tskb.explorer.app" [label="Folder\<\"tskb.explorer.app\"\>\nVite SPA source for the interactive explorer UI. Built separately from the library (npm run build:explorer) and shipped in dist/explorer/\n📁 packages/tskb/explorer-app", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in tskb.explorer.app
          "explorer.spa.main" [label="Module\<\"explorer.spa.main\"\>\nExplorerApp class — top-level SPA controller. mount() orchestrates four setup methods (setupCanvas, setupTooltips, setupRenderer, setupSearch) then loads meta.json via loadInitialData(). The render() method drives the full D3 enter/update/exit cycle on every store change or UI interaction. Interaction handlers (onExpand, onSelect, onTraceLinks) are private methods passed as callbacks to the renderer. UI state (expanded set, selected node, search query) lives on the class instance; graph data lives in GraphStore.\n📁 packages/tskb/explorer-app/src/main.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          subgraph "cluster_tskb_explorer_app_components" {
            label="tskb.explorer.app.components";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.explorer.app.components" [label="Folder\<\"tskb.explorer.app.components\"\>\nNode and edge rendering components for the D3 canvas. Each node type implements NodeComponent; edges are drawn by EdgeRenderer\n📁 packages/tskb/explorer-app/src/components", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.app.components
            "explorer.spa.node-base" [label="Module\<\"explorer.spa.node-base\"\>\nNodeComponent interface (enter, update, anchor, getSize) and BaseNodeRenderer: renders any node type as a rounded-rect card with a <> code preview bubble (top-center) and a + expand bubble (right edge). Ghost nodes (detail._ghost = 'true') render as dashed transparent cards showing only their filename label. Tooltip anchor is the node's right-center SVG position.\n📁 packages/tskb/explorer-app/src/components/nodes/base.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.BaseNodeRenderer" [label="Export\<\"explorer.spa.BaseNodeRenderer\"\>\nDefault NodeComponent implementation: renders any node type as a rounded-rect card with type icon, label, description, edge-count badge, code preview bubble, and expand bubble.\n📁 packages/tskb/explorer-app/src/components/nodes/base.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.spa.edge-renderer" [label="Module\<\"explorer.spa.edge-renderer\"\>\nbuildStructureLinks() derives parent→child links from parentId, marking ghost links via detail._ghost; renderStructureEdges() draws cubic-bezier SVG paths (dashed + lower opacity for ghost links); renderLaneBands() renders lane background bands with labels; buildRelationLinks() shows cross-edges (imports / related-to) only when both endpoints are directly visible; renderRelationEdges() draws tapered filled band shapes between them\n📁 packages/tskb/explorer-app/src/components/edges/EdgeRenderer.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.buildStructureLinks" [label="Export\<\"explorer.spa.buildStructureLinks\"\>\nDerives parent→child StructureLink pairs from the parentId field of every positioned node. Ghost links are flagged for dashed rendering.\n📁 packages/tskb/explorer-app/src/components/edges/EdgeRenderer.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "explorer.spa.renderStructureEdges" [label="Export\<\"explorer.spa.renderStructureEdges\"\>\nDraws parent→child cubic-bezier SVG paths from a StructureLink list. Ghost links render with dashed stroke and reduced opacity.\n📁 packages/tskb/explorer-app/src/components/edges/EdgeRenderer.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.spa.boundary-renderer" [label="Module\<\"explorer.spa.boundary-renderer\"\>\nrenderBoundaryGroups() draws a freeform dashed hull outline around all visible nodes that belong to the same architectural boundary. Hierarchy resolution: only the top-level folder carries detail.boundary; all descendants are resolved by walking parentOf. Hull is computed via d3.polygonHull, perturbed with seeded pseudo-random wobble for a stable hand-drawn look, and smoothed with curveBasisClosed.\n📁 packages/tskb/explorer-app/src/components/BoundaryRenderer.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.renderBoundaryGroups" [label="Export\<\"explorer.spa.renderBoundaryGroups\"\>\nRenders one <g.boundary-group> per boundary into the provided SVG layer. Boundary membership is resolved by walking parentOf from each visible node upward until a node with detail.boundary is found. Uses d3.polygonHull with seeded wobble perturbation and curveBasisClosed for a stable freeform outline. pointer-events: none on all elements.\n📁 packages/tskb/explorer-app/src/components/BoundaryRenderer.ts", shape=component, fillcolor="#C5E1A5", style=filled];

          }

          subgraph "cluster_tskb_explorer_app_graph" {
            label="tskb.explorer.app.graph";
