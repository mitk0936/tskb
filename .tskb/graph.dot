            "tskb.explorer.app.graph" [label="Folder\<\"tskb.explorer.app.graph\"\>\nSPA data layer: chunk type registry, type-safe loader with LRU cache\n📁 packages/tskb/explorer-app/src/graph", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.app.graph
            "explorer.spa.chunk-types" [label="Module\<\"explorer.spa.chunk-types\"\>\nDiscriminated union types for all chunk shapes (MetaChunk, FolderChunk) plus the ChunkRegistry map and a typed URL builder. Extend ChunkRegistry here to add new chunk kinds.\n📁 packages/tskb/explorer-app/src/graph/chunk-types.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "explorer.spa.loader" [label="Module\<\"explorer.spa.loader\"\>\nChunkLoader: type-safe generic fetch keyed by ChunkKind, LRU-bounded in-memory cache (50 chunks), deduplication of in-flight requests\n📁 packages/tskb/explorer-app/src/graph/loader.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.ChunkLoader" [label="Export\<\"explorer.spa.ChunkLoader\"\>\nType-safe chunk fetcher with LRU cache and in-flight deduplication. load(kind, ...args) return type is inferred from ChunkRegistry[K].\n📁 packages/tskb/explorer-app/src/graph/loader.ts", shape=component, fillcolor="#C5E1A5", style=filled];

