    "docs/src/tskb/explorer/spa.tskb.tsx" [label="docs/src/tskb/explorer/spa.tskb.tsx\nExplorer SPA The SPA is built with Vite (D3 in a separate vendor chunk) and lives in the   explorer-...\n📄 docs/src/tskb/explorer/spa.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
