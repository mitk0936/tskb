            "jsx.Li" [label="Export\<\"jsx.Li\"\>\nList item.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.Snippet" [label="Export\<\"jsx.Snippet\"\>\nA type-checked code example.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.Adr" [label="Export\<\"jsx.Adr\"\>\nAn Architecture Decision Record.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.ref" [label="Export\<\"jsx.ref\"\>\nPlaceholder for declaring a typed reference to a registered node.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.Relation" [label="Export\<\"jsx.Relation\"\>\nA labeled edge between two registered nodes.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "DocPriority" [label="Export\<\"DocPriority\"\>\nHow important a doc is: `essential`, `constraint`, or `supplementary`.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.Flow" [label="Export\<\"jsx.Flow\"\>\nA named, ordered sequence of steps through the system.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "jsx.Step" [label="Export\<\"jsx.Step\"\>\nOne step inside a Flow, pointing at a registered node.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "runtime.jsx" [label="Module\<\"runtime.jsx\"\>\nAll JSX tags users can write inside .tskb.tsx files.\n📁 packages/tskb/src/runtime/jsx.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
          "runtime.registry" [label="Module\<\"runtime.registry\"\>\nType definitions for the registry primitives (Folder, Module, Export, Term, File, External).\n📁 packages/tskb/src/runtime/registry.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "Folder" [label="Export\<\"Folder\"\>\nA generic helper to reference folders inside doc files\n📁 packages/tskb/src/runtime/registry.ts", shape=component, fillcolor="#C5E1A5", style=filled];
