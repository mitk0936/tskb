digraph KnowledgeGraph {
  rankdir=TB;
  compound=true;
  node [fontname="Arial", fontsize=10];
  edge [fontname="Arial", fontsize=8];

  subgraph "cluster___TSKB_ROOT__" {
    label="__TSKB.ROOT__";
    style=filled;
    fillcolor="#E3F2FD";
    color="#1976D2";

    "__TSKB.ROOT__" [label="Folder\<\"__TSKB.ROOT__\"\>\nThe root directory (automatically added by tskb)\n📁 .", shape=box, fillcolor="#BBDEFB", style=filled];

    subgraph "cluster_docs" {
      label="docs";
      style=filled;
      fillcolor="#E3F2FD";
      color="#1976D2";

      "docs" [label="Folder\<\"docs\"\>\nA folder that contains all the repo docs (.tskb.tsx) files. Uses its own ts configuration.\n📁 docs", shape=box, fillcolor="#BBDEFB", style=filled];

      // Modules in docs
      "sample.tsconfig.json" [label="Module\<\"sample.tsconfig.json\"\>\nAn example of required tsconfig.json for building <TSKB> docs\n📁 docs/tsconfig.json", shape=ellipse, fillcolor="#FFF9C4", style=filled];

    }

    subgraph "cluster_examples_taskflow_app" {
      label="examples.taskflow-app";
      style=filled;
      fillcolor="#E3F2FD";
      color="#1976D2";

      "examples.taskflow-app" [label="Folder\<\"examples.taskflow-app\"\>\nExample application, not meant to be run, but used as reference for example docs\n📁 examples/taskflow-app", shape=box, fillcolor="#BBDEFB", style=filled];

      subgraph "cluster_Client" {
        label="Client";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1976D2";

        "Client" [label="Folder\<\"Client\"\>\nReact frontend application with components, pages, and state management\n📁 examples/taskflow-app/src/client", shape=box, fillcolor="#BBDEFB", style=filled];

        subgraph "cluster_Components" {
          label="Components";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

