            "tskb.explorer.app.ui" [label="Folder\<\"tskb.explorer.app.ui\"\>\nUI shell components: global spinner, per-node spinner, node hover tooltip, and code preview popup\n📁 packages/tskb/explorer-app/src/ui", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.app.ui
            "explorer.spa.spinner" [label="Module\<\"explorer.spa.spinner\"\>\nGlobal and per-node spinner helpers: showGlobalSpinner/hideGlobalSpinner overlay a full-screen loader; showNodeSpinner/removeNodeSpinner attach a small SVG spinner next to a node while its chunk is loading\n📁 packages/tskb/explorer-app/src/ui/Spinner.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.showNodeSpinner" [label="Export\<\"explorer.spa.showNodeSpinner\"\>\nAppends a small animated SVG ring at a given (x, y) position inside the node canvas layer. Returns the SVG group element so the caller can remove it via removeNodeSpinner.\n📁 packages/tskb/explorer-app/src/ui/Spinner.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "explorer.spa.removeNodeSpinner" [label="Export\<\"explorer.spa.removeNodeSpinner\"\>\nRemoves the SVG group returned by showNodeSpinner from the DOM. Called in the finally block of ExplorerApp.onExpand() after the chunk fetch resolves or rejects.\n📁 packages/tskb/explorer-app/src/ui/Spinner.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.spa.node-tooltip" [label="Module\<\"explorer.spa.node-tooltip\"\>\nHover tooltip anchored to the node's right-center SVG position. Shows a coloured dot, node name, monospace path, and description. Receives updateNodeTooltipTransform() calls from main.ts on every zoom event so it repositions to track the node. Uses mouseover/mouseout bubbling with relatedTarget boundary guards to avoid flicker on child SVG elements.\n📁 packages/tskb/explorer-app/src/ui/NodeTooltip.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "explorer.spa.code-tooltip" [label="Module\<\"explorer.spa.code-tooltip\"\>\nToggle-based code preview popup for module nodes. Click the <> bubble to show/hide; clicking the same node again dismisses it; clicking outside also dismisses. Renders morphology lines with an inline TypeScript tokenizer (no runtime deps) for syntax highlighting, prepended by import lines with a blank-line separator.\n📁 packages/tskb/explorer-app/src/ui/CodeTooltip.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

