        "tests.e2e" [label="Folder\<\"tests.e2e\"\>\nE2E tests that exercise the full tskb pipeline: init scaffolding, build, and every query command\n📁 tests/e2e", shape=box, fillcolor="#BBDEFB", style=filled];

        subgraph "cluster_tests_e2e_fixture" {
