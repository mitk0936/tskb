  }

  // Terms
  subgraph "cluster_terms" {
    label="Terms";
    style=dashed;
    color=gray;
    "library" [label="Term\<\"library\"\>\nRefers to the <TSKB> package with all of its capabilities, interfaces and commands", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "cli" [label="Term\<\"cli\"\>\nThe library exposes a command line interface for main actions - build docs to json graph, generate visualization, search nodes from the graph by query", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxRuntime" [label="Term\<\"jsxRuntime\"\>\nTSKB provides a custom JSX runtime (jsx-runtime module) that transforms TSX documentation syntax into a knowledge graph. Configured via tsconfig's jsxImportSource option, it processes JSX elements differently from React - instead of DOM rendering, it extracts documentation structure, references, and code snippets for analysis and visualization.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "tsProgram" [label="Term\<\"tsProgram\"\>\nTypeScript compiler Program from source files and tsconfig settings that enables static analysis of code structure, types, and symbols without emitting JavaScript output.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "registry" [label="Term\<\"registry\"\>\nThe global namespace (declare global { namespace tskb }) containing typed interfaces (Folders, Modules, Exports, Terms) that serve as a type-safe vocabulary registry, enabling autocomplete and type-checked references across all .tskb.tsx documentation files.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "graph" [label="Term\<\"graph\"\>\nRefers to th raw output of the library, where it constructs all the relations and connections between folders, modules, exports, terms, docs, etc. In its raw form it is a json file", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "dotFile" [label="Term\<\"dotFile\"\>\nA Graphviz DOT format file that describes the graph structure with nodes and edges, used for rendering visual diagrams of the architecture", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "searchResult" [label="Term\<\"searchResult\"\>\nResult from searching the knowledge graph - includes ranked matches with scores across the entire graph, found via fuzzy matching on IDs, descriptions, and paths", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "knowledgeChunk" [label="Term\<\"knowledgeChunk\"\>\nAn on-demand JSON fragment of the knowledge graph. meta.json contains root folder, top-level folder summaries, docs, flows, and terms. folder-{id}.json contains modules, exports, sub-folders, and import edges for one folder.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "explorerLane" [label="Term\<\"explorerLane\"\>\nA horizontal section of the explorer SVG canvas. Three lanes stack vertically: Structure (code hierarchy, d3.tree), Docs (priority-ordered horizontal list), and Terms/Flows. Each lane has a labeled background band.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "nodeComponent" [label="Term\<\"nodeComponent\"\>\nInterface for rendering a node type in the D3 canvas: enter() appends SVG elements, update() repositions them, anchor() returns edge connection points, getSize() returns bounding box. Implemented by BaseNodeRenderer; override per type.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "lruChunkCache" [label="Term\<\"lruChunkCache\"\>\nBounded LRU cache inside ChunkLoader (max 50 entries). Map insertion order is used for O(1) LRU: on get, entry is deleted and re-inserted; on set overflow, oldest key is evicted. Chunks are immutable so no invalidation is needed.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "explorerStaticExport" [label="Term\<\"explorerStaticExport\"\>\nSelf-contained static export produced by `tskb explore --export`. Contains the pre-built SPA (index.html + hashed JS chunks) and all graph chunk JSON files. Works offline via file:// because the SPA uses relative fetch paths.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "ghostNode" [label="Term\<\"ghostNode\"\>\nA placeholder ExplorerNode with detail._ghost = 'true'. Ghost nodes represent filesystem directories or files visible in the tree that are not declared in the knowledge graph. Two sources: (1) buildGhostIntermediaryChains() in transform.ts synthesizes ghost FolderChunks for every intermediate filesystem directory between a declared folder's path and its owned modules; (2) injectGhostNodes() in transform.ts adds ghost module/folder nodes from folder.children scanner data. Lane-engine also injects transient ghost placeholders for collapsed folders with _childCount > 0 to pre-reserve tree space. All ghost nodes render as dashed transparent cards with only a filename label.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "ast" [label="Term\<\"ast\"\>\nAbstract Syntax Tree - TypeScript's tree representation of source code, used by the compiler API to analyze code structure", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "declarationMerging" [label="Term\<\"declarationMerging\"\>\nTypeScript feature that allows multiple declarations with the same name to be merged into a single definition, enabling distributed vocabulary across files", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "typeChecker" [label="Term\<\"typeChecker\"\>\nTypeScript compiler component that resolves types, validates code, and provides type information for symbols in the AST", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "literalType" [label="Term\<\"literalType\"\>\nA TypeScript type that represents a specific literal value (e.g., string literal 'hello' or number literal 42), used to extract constant values from type definitions", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxElement" [label="Term\<\"jsxElement\"\>\nA JSX syntax node in the TypeScript AST representing an element like <Doc> or <P>, containing opening tag, children, and closing tag", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxExpression" [label="Term\<\"jsxExpression\"\>\nA TypeScript AST node representing an embedded expression in JSX curly braces like {ref as tskb.Folders['Auth']}", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "typeAssertion" [label="Term\<\"typeAssertion\"\>\nTypeScript 'as' syntax that casts a value to a specific type, used in tskb to reference vocabulary items: {ref as tskb.Modules['X']}", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "depthFirstTraversal" [label="Term\<\"depthFirstTraversal\"\>\nTree traversal algorithm that explores as far as possible along each branch before backtracking, used to visit all JSX nodes in order", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "cliPipeline" [label="Term\<\"cliPipeline\"\>\nThe build process: file discovery → program initialization → registry extraction → doc extraction → graph construction → output generation (JSON, DOT, skill/instructions)", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "commandRouting" [label="Term\<\"commandRouting\"\>\nThe CLI's mechanism for parsing arguments and delegating to the appropriate command handler (init, build, search, pick, context, ls, docs, or flows)", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "globPattern" [label="Term\<\"globPattern\"\>\nFile pattern syntax (e.g., '**/*.tskb.tsx') used to match documentation files for processing", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "folderIdNavigation" [label="Term\<\"folderIdNavigation\"\>\nNavigation strategy using folder IDs from the knowledge graph registry (e.g., 'tskb.cli', 'Package.Root') instead of filesystem paths", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "tskbOutputDir" [label="Term\<\"tskbOutputDir\"\>\nThe .tskb/ directory containing all build outputs: graph.json and graph.dot", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "tskbInit" [label="Term\<\"tskbInit\"\>\nInteractive scaffolder command that creates docs folder, tsconfig, starter doc, package.json script, and opt-in AI integration directories", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "resolvedVia" [label="Term\<\"resolvedVia\"\>\nResolution strategy used by resolveNode: 'id' (exact match), 'path' (filesystem path match), or 'nearest-parent' (deepest folder whose path is a prefix of the identifier)", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "repositoryPattern" [label="Term\<\"repositoryPattern\"\>\nData access abstraction layer that separates business logic from database operations", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "serviceLayer" [label="Term\<\"serviceLayer\"\>\nBusiness logic layer that orchestrates operations between controllers and repositories", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "contextProvider" [label="Term\<\"contextProvider\"\>\nReact pattern for managing and sharing state across component tree without prop drilling", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jwt" [label="Term\<\"jwt\"\>\nJSON Web Token - stateless authentication mechanism using signed tokens", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "pagination" [label="Term\<\"pagination\"\>\nTechnique for splitting large datasets into smaller pages for efficient data transfer", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "middlewareChain" [label="Term\<\"middlewareChain\"\>\nSequential processing pattern where request passes through multiple handlers", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "dependencyInjection" [label="Term\<\"dependencyInjection\"\>\nDesign pattern where dependencies are provided to a class rather than created internally", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "crudOperations" [label="Term\<\"crudOperations\"\>\nCreate, Read, Update, Delete - fundamental data operations", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "typeGuards" [label="Term\<\"typeGuards\"\>\nTypeScript runtime checks that narrow types within conditional blocks", shape=diamond, fillcolor="#F0F4C3", style=filled];
  }

  // Externals
  subgraph "cluster_externals" {
    label="Externals";
    style=dashed;
    color=gray;
    "pg" [label="pg\nPostgreSQL client for Node.js\nurl: https://node-postgres.com\nkind: npm-package", shape=hexagon, fillcolor="#B2EBF2", style=filled];
  }

  // Flows
  subgraph "cluster_flows" {
    label="Flows";
    style=dashed;
    color=gray;
    "e2e-test-execution" [label="e2e-test-execution\nFull E2E run: global setup builds fixture graph, test files exercise every CLI command, teardown cleans output\n1. vitest.config (Discovers test files, registers global setup)\n2. tests.global-setup (Builds fixture graph once via tskb build)\n3. tests.helpers (Provides CLI runners and graph loader to all test files)\n4. tests.global-setup (Teardown cleans .tskb/ output directory)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "init-scaffolding-test" [label="init-scaffolding-test\nHow the init command is tested: copies fixture to temp dir, runs init, asserts generated files\n1. tests.helpers (Copies fixture src/ into a temp directory)\n2. cli.build (Runs tskb init --yes in the temp directory)\n3. tests.e2e (Asserts scaffolded files: tsconfig, starter doc, scripts, AI dirs)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "build-pipeline" [label="build-pipeline\nThe tskb build process: source files through extraction to knowledge graph outputs\n1. cli.build (Orchestrates the pipeline: file discovery, extraction, graph building, output generation)\n2. extractRegistry (Scans TypeScript AST for global tskb namespace declarations (Folders, Modules, Exports, Terms))\n3. extractDocs (Traverses JSX trees in .tskb.tsx files, extracting content, references, relations, and flows)\n4. buildGraph (Merges registry and docs into a unified graph with nodes, edges, and hierarchy)\n5. generateDot (Transforms the graph into DOT format for Graphviz visualization)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "static-analysis" [label="static-analysis\nTypeScript Program creation through extraction to graph\n1. ts.createProgram (creates Program from tsconfig + source files)\n2. extraction.registry (walks AST for Folders, Modules, Terms, Exports)\n3. extraction.documentation (parses JSX trees for content and references)\n4. graph.builder (assembles nodes and edges into knowledge graph)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "graph-to-chunks-transform" [label="graph-to-chunks-transform\nHow KnowledgeGraph becomes ExplorerChunks: edge indexing, meta assembly, recursive folder chunking, ghost node injection, child count patching\n1. cli.commands.explore (Reads graph.json from disk into KnowledgeGraph)\n2. explorer.transform (groupEdgesByKey() builds edgesBySource + edgesByTarget indexes from all graph edges)\n3. explorer.transformGraph (Assembles MetaChunk: root node, topFolders, docs, flows, terms, externals, cross-lane reference edges)\n4. explorer.transformGraph (buildAllFolderChunksRecursively() depth-first: modules, exports, subfolders, internal + external import edges per folder)\n5. explorer.transform (buildGhostIntermediaryChains() synthesizes FolderChunks for every intermediate filesystem directory between a declared folder path and its owned modules/subfolders)\n6. explorer.transform (injectGhostNodes() adds placeholder ExplorerNodes for undeclared .ts/.tsx files and undeclared child directories recorded in folder.children scanner data)\n7. explorer.transform (patchFolderChildCounts() finalizes _hasChildren + _childCount on all folder nodes after ghost injection)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-expand-flow" [label="explorer-expand-flow\nUser expands a folder node: chunk is fetched, store updated, layout recomputed, SVG re-rendered\n1. explorer.spa.node-base (User clicks + expand button; BaseNodeRenderer fires the onExpand callback)\n2. explorer.spa.main (ExplorerApp.onExpand(): calls showNodeSpinner, delegates to loader, calls removeNodeSpinner in finally; adds node id to expanded set)\n3. explorer.spa.loader (ChunkLoader.load('folder', id) — returns cached chunk or fetches /chunks/folder-{sanitizedId}.json)\n4. explorer.spa.store (store.loadFolderChunk() stores chunk; store notifies subscribers, triggering ExplorerApp.render())\n5. explorer.spa.computeLayout (render() calls computeLayout(store, expanded) — rebuilds d3.hierarchy and recomputes all SVG positions)\n6. explorer.spa.buildStructureLinks (render() calls buildStructureLinks() — derives parent→child link list from updated parentId fields)\n7. explorer.spa.renderStructureEdges (render() calls renderStructureEdges() — redraws cubic-bezier SVG paths; ghost links rendered dashed)\n8. explorer.spa.node-base (render() D3 enter/update/exit — new node cards enter with fade-in, collapsed nodes exit with fade-out)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-serve-flow" [label="explorer-serve-flow\ntskb explore: CLI finds graph, transforms chunks, starts HTTP server, browser loads SPA and fetches chunks on demand\n1. explorer.explore (Reads graph.json, branches on --export flag)\n2. explorer.transformGraph (Converts KnowledgeGraph into MetaChunk + FolderChunks, serializes all to JSON strings)\n3. explorer.serveExplorer (Starts http server: /chunks/*.json reads from in-memory cache; /* serves SPA assets)\n4. explorer.spa.main (ExplorerApp.mount(): setupCanvas (D3 SVG + zoom/pan), setupRenderer, setupSearch, then loadInitialData fetches meta.json)\n5. explorer.spa.lane-engine (computeLayout() positions all visible nodes across three lanes)\n6. explorer.spa.node-base (D3 enter/update renders node cards into SVG groups)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-export-flow" [label="explorer-export-flow\ntskb explore --export: CLI finds graph, transforms all chunks, copies SPA assets, writes chunk JSON files to disk\n1. explorer.explore (Reads graph.json, detects --export flag, resolves output directory (default: .tskb/explorer))\n2. explorer.transformGraph (Converts KnowledgeGraph into MetaChunk + FolderChunks)\n3. explorer.export (copyDir() recursively copies dist/explorer/ SPA assets to output directory)\n4. explorer.exportExplorer (Writes chunks/meta.json and chunks/folder-{id}.json for every folder chunk)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-boot" [label="explorer-app-boot\nExplorerApp.mount(): four setup phases then meta fetch that triggers the first render\n1. explorer.spa.ExplorerApp (new ExplorerApp().mount() called on page load)\n2. explorer.spa.ExplorerApp.setupCanvas (Appends zoom-layer → lane-bg-layer / edge-layer / node-layer; configures d3.zoom with tooltip transform propagation; mounts detail panel)\n3. explorer.spa.ExplorerApp.setupTooltips (mountNodeTooltip() and mountCodeTooltip() attach DOM tooltip elements anchored to the SVG)\n4. explorer.spa.ExplorerApp.setupRenderer (createNodeRenderer() wires onExpand / onSelect / onTraceLinks / hasChildren / code preview callbacks to ExplorerApp instance methods)\n5. explorer.spa.ExplorerApp.setupSearch (Search input 'input' event updates searchQuery and calls render())\n6. explorer.spa.ExplorerApp.loadInitialData (loader.load('meta') fetches /chunks/meta.json; global spinner shown while pending)\n7. explorer.spa.store (store.loadMeta() stores the chunk and notifies the render subscriber)\n8. explorer.spa.lane-engine (First render(): computeLayout positions top-folder nodes across the Structure lane)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-render" [label="explorer-app-render\nExplorerApp.render(): layout → edges → D3 enter/update/exit → search dim\n1. explorer.spa.ExplorerApp.render (Triggered by store subscription or direct call from interaction handler)\n2. explorer.spa.computeLayout (computeLayout(store, expanded): builds d3.hierarchy from visible tree, runs d3.tree for left-to-right positions)\n3. explorer.spa.edge-renderer (renderLaneBands(): draws labeled background bands for Structure, Docs, Terms/Flows lanes)\n4. explorer.spa.buildStructureLinks (buildStructureLinks(structureNodes): derives parent→child StructureLink pairs from parentId fields)\n5. explorer.spa.renderStructureEdges (renderStructureEdges(): redraws cubic-bezier SVG paths; ghost links get dashed stroke)\n6. explorer.spa.node-base (D3 enter: new <g.node> elements appended; renderer.enter() initialises rect, icon, label, badge, expand bubble)\n7. explorer.spa.node-base (D3 update: renderer.update() repositions and reskins all merged nodes)\n8. explorer.spa.node-base (D3 exit: removed nodes fade opacity→0 and translate +8px before removal; search dim sets 0.15 on non-matching nodes)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-expand" [label="explorer-app-expand\nExplorerApp.onExpand(): fetch chunk if needed, update expanded set, re-render\n1. explorer.spa.node-base (User clicks + button; BaseNodeRenderer fires the onExpand callback)\n2. explorer.spa.ExplorerApp.onExpand (If already expanded: collapseDescendants() clears the subtree, calls render())\n3. explorer.spa.showNodeSpinner (If chunk not cached: showNodeSpinner() appends animated SVG ring next to the node)\n4. explorer.spa.loader (loader.load('folder', id): cache hit or fetches /chunks/folder-{sanitizedId}.json)\n5. explorer.spa.removeNodeSpinner (removeNodeSpinner() called in finally — always removes spinner whether fetch succeeded or failed)\n6. explorer.spa.store (store.loadFolderChunk() stores chunk and notifies subscribers)\n7. explorer.spa.ExplorerApp.render (render() called after expanded set update — new nodes enter, layout recomputed)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "module-morphology-extraction" [label="module-morphology-extraction\nHow a Module declaration becomes a fully enriched graph node with exports, imports, and type stubs\n1. extractRegistry (collects Module declarations from tskb namespace)\n2. extractModuleMorphology (resolves source file, classifies exports, renders code stubs)\n3. extractModuleImports (walks import declarations for symbols and paths)\n4. graph.builder (assembles enriched ModuleNode with edges)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "login-flow" [label="login-flow\nUser authentication from HTTP request to session token\n1. AuthMiddleware (Validates request format)\n2. AuthService (Checks credentials, generates JWT)\n3. Database (Queries user record)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "task-creation" [label="task-creation\nTask creation with validation and notification\n1. TaskService (Validates input, applies business rules)\n2. TaskRepository (Persists task to database)\n3. NotificationService (Notifies assigned users)", shape=cds, fillcolor="#C8E6C9", style=filled];
  }

  // Documentation
