            "tskb.explorer.app.layout" [label="Folder\<\"tskb.explorer.app.layout\"\>\nLane layout engine: computes SVG positions for structure (d3.tree), docs, and other lanes\n📁 packages/tskb/explorer-app/src/layout", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.app.layout
            "explorer.spa.lane-engine" [label="Module\<\"explorer.spa.lane-engine\"\>\ncomputeLayout(): builds a d3.hierarchy from visible structure nodes, runs d3.tree for left-to-right positioning, then lays docs and other nodes as horizontal lists below. Collapsed folders with _childCount > 0 inject up to 4 ghost placeholder nodes so the tree reserves space for their children.\n📁 packages/tskb/explorer-app/src/layout/lane-engine.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.spa.computeLayout" [label="Export\<\"explorer.spa.computeLayout\"\>\nComputes SVG positions for all visible nodes across three lanes (Structure, Docs, Terms/Flows). Called on every expand/collapse; returns a LaneLayout consumed by node and edge renderers.\n📁 packages/tskb/explorer-app/src/layout/lane-engine.ts", shape=component, fillcolor="#C5E1A5", style=filled];

