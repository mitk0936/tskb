          color="#1976D2";

          "tskb.runtime" [label="Folder\<\"tskb.runtime\"\>\nRegistry types and JSX primitives. No runtime code — these are the types and tags users import.\n📁 packages/tskb/src/runtime", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in tskb.runtime
          "Jsx.runtime.js" [label="Module\<\"Jsx.runtime.js\"\>\nThe JSX runtime — every tskb JSX tag (Doc, P, Flow, etc.) is a function exported here.\n📁 packages/tskb/src/runtime/jsx.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "jsx.Doc" [label="Export\<\"jsx.Doc\"\>\nThe root tag of a doc file. Answers one question via its `explains` prop.\n📁 packages/tskb/src/runtime/jsx.ts", shape=component, fillcolor="#C5E1A5", style=filled];
