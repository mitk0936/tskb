  // Terms
  subgraph "cluster_terms" {
    label="Terms";
    style=dashed;
    color=gray;
    "library" [label="Term\<\"library\"\>\nThe tskb package itself — its CLI, JSX runtime, and types for writing docs.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "cli" [label="Term\<\"cli\"\>\nThe command-line tool shipped by the package. Run as `tskb` after install. Builds the graph, runs queries, opens the explorer.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxRuntime" [label="Term\<\"jsxRuntime\"\>\nA custom JSX runtime that turns .tskb.tsx files into a knowledge graph instead of DOM. Picked up by the docs tsconfig via `jsxImportSource: \"tskb\"`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "registry" [label="Term\<\"registry\"\>\nThe global `namespace tskb` where Folders, Modules, Exports, and Terms are declared. All .tskb.tsx files share one registry — declarations merge across files.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "graph" [label="Term\<\"graph\"\>\nThe JSON output of the build: every node (folder, module, export, term, doc, flow) and the edges between them. Saved to `.tskb/graph.json`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "tsProgram" [label="Term\<\"tsProgram\"\>\nA TypeScript compiler `Program` built from source files and a tsconfig. tskb uses it to read the AST, types, and symbols of your code — without emitting JavaScript.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "knowledgeChunk" [label="Term\<\"knowledgeChunk\"\>\nA JSON piece of the graph the SPA loads on demand. The meta chunk holds top-level info; one folder chunk per folder holds its contents.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "explorerLane" [label="Term\<\"explorerLane\"\>\nA horizontal band on the explorer canvas. Lanes group different kinds of nodes side by side.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "nodeComponent" [label="Term\<\"nodeComponent\"\>\nThe interface a node type implements to render itself on the canvas.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "lruChunkCache" [label="Term\<\"lruChunkCache\"\>\nA bounded cache inside the SPA. Keeps recently loaded chunks; drops the oldest when full.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "explorerStaticExport" [label="Term\<\"explorerStaticExport\"\>\nA self-contained explorer folder that opens directly from the file system, no server needed.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "ghostNode" [label="Term\<\"ghostNode\"\>\nA placeholder node for a folder or file that exists on disk but isn't declared in the graph. Drawn as a faded card.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "dotFile" [label="Term\<\"dotFile\"\>\nA Graphviz DOT file. Plain text describing nodes and edges. Used to draw the graph as a diagram with `dot -Tpng`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "ast" [label="Term\<\"ast\"\>\nAbstract Syntax Tree. TypeScript's tree shape of source code.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "declarationMerging" [label="Term\<\"declarationMerging\"\>\nTypeScript's rule that merges declarations with the same name. Lets the registry be split across files.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "typeChecker" [label="Term\<\"typeChecker\"\>\nTypeScript's component that resolves types and gives type info for symbols.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "literalType" [label="Term\<\"literalType\"\>\nA type that represents one specific value, like the string `'hello'`. Used to read constants out of type definitions.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxElement" [label="Term\<\"jsxElement\"\>\nA JSX node in the source tree, like `<Doc>` or `<P>`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "jsxExpression" [label="Term\<\"jsxExpression\"\>\nA `{ ... }` expression embedded inside JSX.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "typeAssertion" [label="Term\<\"typeAssertion\"\>\nTypeScript's `as` syntax. tskb uses it to point a `ref` at a registry entry: `ref as tskb.Modules['X']`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "depthFirstTraversal" [label="Term\<\"depthFirstTraversal\"\>\nTree traversal that follows each branch to its end before moving to the next. Used to walk JSX in order.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "constantReferencesMap" [label="Term\<\"constantReferencesMap\"\>\nA lookup from each `const` in a doc file to the registry node it points to.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "refCategoryMap" [label="Term\<\"refCategoryMap\"\>\nA lookup from a JSX tag name to the registry category it belongs to.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "globPattern" [label="Term\<\"globPattern\"\>\nA file-matching pattern like `**/*.tskb.tsx`. Used to pick which doc files to build.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "tskbOutputDir" [label="Term\<\"tskbOutputDir\"\>\nThe `.tskb/` folder. Holds the build output: `graph.json` and `graph.dot`.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "searchResult" [label="Term\<\"searchResult\"\>\nA match returned by `tskb search`. A node plus a score from 0 to 1; higher means a better match.", shape=diamond, fillcolor="#F0F4C3", style=filled];
    "resolvedVia" [label="Term\<\"resolvedVia\"\>\nHow `resolveNode` found a match: by exact ID, by path, or by walking up to the nearest parent folder.", shape=diamond, fillcolor="#F0F4C3", style=filled];
  }

  // Externals
  subgraph "cluster_externals" {
    label="Externals";
    style=dashed;
    color=gray;
    "vitest" [label="vitest\nThe test runner.\nurl: https://vitest.dev\nkind: npm-package", shape=hexagon, fillcolor="#B2EBF2", style=filled];
    "npm" [label="npm\nnpm package registry where tskb is published. The package includes the CLI binary, library entry point, JSX runtime, and pre-built explorer SPA assets.\nurl: https://www.npmjs.com/package/tskb\nkind: package-registry", shape=hexagon, fillcolor="#B2EBF2", style=filled];
    "typescript" [label="typescript\nTypeScript compiler API (the 'typescript' npm package). Provides the AST, type checker, and symbol resolution used throughout registry extraction and documentation parsing.\nurl: https://www.typescriptlang.org\nkind: npm-package", shape=hexagon, fillcolor="#B2EBF2", style=filled];
    "d3" [label="d3\nData-visualisation library used for layout, zoom, and SVG drawing.\nurl: https://d3js.org\nkind: npm-package", shape=hexagon, fillcolor="#B2EBF2", style=filled];
    "vite" [label="vite\nBuild tool that bundles the explorer SPA.\nurl: https://vitejs.dev\nkind: npm-package", shape=hexagon, fillcolor="#B2EBF2", style=filled];
  }

  // Flows
  subgraph "cluster_flows" {
    label="Flows";
    style=dashed;
    color=gray;
    "e2e-test-execution" [label="e2e-test-execution\nDeveloper runs `npm test`: Vitest loads config, global setup builds the fixture graph, test files exercise every CLI command, teardown cleans output\n1. vitest.config (discovers test files, registers global setup)\n2. tests.global-setup (builds fixture graph once via tskb build)\n3. tests.helpers (provides CLI runners and graph loader to all test files)\n4. tests.global-setup (teardown cleans .tskb/ output directory)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "init-scaffolding-test" [label="init-scaffolding-test\n`init.test.ts` runs: copies fixture to a temp dir, invokes `tskb init`, asserts the generated files\n1. tests.init (orchestrates the test: arranges temp dir, runs init, asserts output)\n2. tests.helpers (copies fixture src/ into the temp directory)\n3. cli.build (runs tskb init --yes in the temp directory)\n4. tests.init (asserts scaffolded files: tsconfig, starter doc, scripts, AI dirs)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "build-pipeline" [label="build-pipeline\nThe tskb build process: source files through extraction to knowledge graph outputs\n1. cli.build (Orchestrates the pipeline: file discovery, extraction, graph building, output generation)\n2. extractRegistry (Scans TypeScript AST for global tskb namespace declarations (Folders, Modules, Exports, Terms))\n3. extractDocs (Receives completed registry; traverses JSX trees to extract content, references, relations, and flows — embeds data-node-display in reference links using registry-resolved paths)\n4. buildGraph (Merges registry and docs into a unified graph with nodes, edges, and hierarchy)\n5. generateDot (Transforms the graph into DOT format for Graphviz visualization)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "static-analysis" [label="static-analysis\n`tskb build` invokes createProgram to set up TypeScript static analysis, then hands the Program to extraction and graph assembly\n1. ts.createProgram (creates Program from tsconfig + source files)\n2. extraction.registry (walks AST for Folders, Modules, Terms, Exports)\n3. extraction.documentation (parses JSX trees for content and references)\n4. graph.builder (assembles nodes and edges into knowledge graph)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "graph-to-chunks-transform" [label="graph-to-chunks-transform\nThe explorer asks transformGraph to chunk a KnowledgeGraph for delivery: edges are indexed, the meta chunk is built, folder chunks are walked, ghosts are filled in, then counts and ordering are finalised\n1. explorer.transformGraph (entry point: instantiates the transformer, indexes edges by source and target, then runs the phases below)\n2. explorer.transform (builds the meta chunk: root folder, top folders, docs, flows, terms, externals, and cross-lane edges)\n3. explorer.transform (recursively builds one folder chunk per folder with its direct modules, exports, sub-folders, and import edges (split into internal vs external))\n4. explorer.transform (fills in ghost intermediary folders for path gaps between a declared folder and its modules, then injects ghost nodes for undeclared files and folders found by the scanner)\n5. explorer.transform (patches folder child counts so the SPA can show expand affordances, sorts chunk contents alphabetically, and builds the parent-of map)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-expand-flow" [label="explorer-expand-flow\nUser expands a folder node: chunk is fetched, store updated, layout recomputed, SVG re-rendered\n1. explorer.spa.node-base (User clicks + expand button; BaseNodeRenderer fires the onExpand callback)\n2. explorer.spa.main (ExplorerApp.onExpand(): calls showNodeSpinner, delegates to loader, calls removeNodeSpinner in finally; adds node id to expanded set)\n3. explorer.spa.loader (ChunkLoader.load('folder', id) — returns cached chunk or fetches /chunks/folder-{sanitizedId}.json)\n4. explorer.spa.store (store.loadFolderChunk() stores chunk; store notifies subscribers, triggering ExplorerApp.render())\n5. explorer.spa.computeLayout (render() calls computeLayout(store, expanded) — rebuilds d3.hierarchy and recomputes all SVG positions)\n6. explorer.spa.buildStructureLinks (render() calls buildStructureLinks() — derives parent→child link list from updated parentId fields)\n7. explorer.spa.renderStructureEdges (render() calls renderStructureEdges() — redraws cubic-bezier SVG paths; ghost links rendered dashed)\n8. explorer.spa.node-base (render() D3 enter/update/exit — new node cards enter with fade-in, collapsed nodes exit with fade-out)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-serve-flow" [label="explorer-serve-flow\nDeveloper runs `tskb explore`: the CLI loads the graph, transforms it into chunks, starts an HTTP server, and the browser loads the SPA and fetches chunks on demand\n1. explorer.explore (loads the graph file and routes to the serve path)\n2. explorer.transformGraph (converts the KnowledgeGraph into a MetaChunk and one FolderChunk per folder, held in memory)\n3. explorer.serveExplorer (starts the HTTP server: chunk routes serve the in-memory chunks as JSON; everything else serves the SPA assets)\n4. explorer.spa.main (ExplorerApp mounts on page load: sets up canvas, renderer, and search, then fetches the meta chunk)\n5. explorer.spa.lane-engine (positions all visible nodes across the three lanes)\n6. explorer.spa.node-base (D3 enter/update renders node cards into SVG groups)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-export-flow" [label="explorer-export-flow\nDeveloper runs the explorer export command: the graph file is read, chunks are transformed in memory, then the pre-built SPA and chunk files are written to the output directory\n1. explorer.explore (reads the graph file and resolves the output directory from the export flag)\n2. explorer.transformGraph (converts KnowledgeGraph into a MetaChunk plus one FolderChunk per folder, held in memory)\n3. explorer.exportExplorer (copies the pre-built SPA into the output directory and writes all chunk JSON files alongside it)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-boot" [label="explorer-app-boot\nExplorerApp.mount(): four setup phases then meta fetch that triggers the first render\n1. explorer.spa.ExplorerApp (new ExplorerApp().mount() called on page load)\n2. explorer.spa.ExplorerApp.setupCanvas (Appends zoom-layer → lane-bg-layer / boundary-layer / edge-layer / node-layer; configures d3.zoom with tooltip transform propagation)\n3. explorer.spa.ExplorerApp.setupTooltips (mountNodeTooltip() and mountCodeTooltip() attach DOM tooltip elements anchored to the SVG)\n4. explorer.spa.ExplorerApp.setupRenderer (createNodeRenderer() wires onExpand / onSelect / onTraceLinks / hasChildren / code preview callbacks to ExplorerApp instance methods)\n5. explorer.spa.ExplorerApp.setupSearch (Search input 'input' event updates searchQuery and calls render())\n6. explorer.spa.ExplorerApp.loadInitialData (loader.load('meta') fetches /chunks/meta.json; global spinner shown while pending)\n7. explorer.spa.store (store.loadMeta() stores the chunk and notifies the render subscriber)\n8. explorer.spa.lane-engine (First render(): computeLayout positions top-folder nodes across the Structure lane)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-render" [label="explorer-app-render\nA store update or interaction calls ExplorerApp.render(): layout, edges, D3 join, search dim\n1. explorer.spa.ExplorerApp.render (triggered by store subscription or a direct call from an interaction handler)\n2. explorer.spa.computeLayout (computeLayout(store, expanded): builds d3.hierarchy from visible tree, runs d3.tree for left-to-right positions. Result cached until layoutDirty is set.)\n3. explorer.spa.computeRenderState (computeRenderState(store, layout, searchQuery): derives allNodes, canvasW, structureLinks, relationLinks, matchIds. Pure — no D3.)\n4. explorer.spa.edge-renderer (renderLaneBands(): draws labeled background bands for Structure and Externals lanes)\n5. explorer.spa.buildStructureLinks (buildStructureLinks(structureNodes): derives parent→child StructureLink pairs from parentId fields)\n6. explorer.spa.renderStructureEdges (renderStructureEdges(): redraws cubic-bezier SVG paths; ghost links get dashed stroke)\n7. explorer.spa.node-base (D3 enter/update/exit: new node cards appended, merged nodes repositioned, removed nodes fade out; search dim sets 0.15 on non-matching nodes)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "explorer-app-expand" [label="explorer-app-expand\nExplorerApp.onExpand(): fetch chunk if needed, update expanded set, re-render\n1. explorer.spa.node-base (User clicks + button; BaseNodeRenderer fires the onExpand callback)\n2. explorer.spa.ExplorerApp.onExpand (If already expanded: collapseDescendants() clears the subtree, calls render())\n3. explorer.spa.showNodeSpinner (If chunk not cached: showNodeSpinner() appends animated SVG ring next to the node)\n4. explorer.spa.loader (loader.load('folder', id): cache hit or fetches /chunks/folder-{sanitizedId}.json)\n5. explorer.spa.removeNodeSpinner (removeNodeSpinner() called in finally — always removes spinner whether fetch succeeded or failed)\n6. explorer.spa.store (store.loadFolderChunk() stores chunk and notifies subscribers)\n7. explorer.spa.ExplorerApp.render (render() called after expanded set update — new nodes enter, layout recomputed)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "module-morphology-extraction" [label="module-morphology-extraction\nDuring `tskb build`, extractRegistry enriches every Module declaration with its public API: exports, imports, and type stubs\n1. extractRegistry (collects Module declarations from tskb namespace)\n2. extractModuleMorphology (resolves source file, classifies exports, renders code stubs)\n3. extractModuleImports (walks import declarations for symbols and paths)\n4. graph.builder (assembles enriched ModuleNode with edges)", shape=cds, fillcolor="#C8E6C9", style=filled];
    "docs-extraction-pipeline" [label="docs-extraction-pipeline\nSingle .tskb.tsx file through extraction: constant map → JSX traversal → HTML + references\n1. extractDocs (Iterates Program source files; dispatches matched .tsx files to extractFromTsxFile)\n2. extractFromTsxFile (Builds constant ref map, finds default export, instantiates JsxExtractor)\n3. buildRefMap (Walks all variable declarations; maps const names → {category, name} via type-assertion parsing)\n4. extraction.registry (Passed in as optional param; queried by buildRefLink to pre-compute data-node-display values)\n5. JsxExtractor (Depth-first JSX traversal via visitElement dispatch: structural tags → HTML, XxxRef / inline refs → buildRefLink; Flow and Relation elements validated and collected)\n6. buildRefLink (Emits <a class=tskb-ref data-node-id data-node-type data-node-display>; pushes id into refs sub-array)\n7. resolveNodeMeta (Called per Flow step: probes all registry maps to return {nodeType, display} for the step anchor)\n8. ExtractedDoc (Returned: filePath, HTML content, references arrays, flows[], relations[])\n9. graph.builder (Consumes ExtractedDoc: creates DocNode + FlowNode entries and references/flow-step edges)", shape=cds, fillcolor="#C8E6C9", style=filled];
  }

