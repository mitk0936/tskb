            "graph.types" [label="Module\<\"graph.types\"\>\nType definitions for the knowledge graph.\n📁 packages/tskb/src/core/graph/types.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "KnowledgeGraph" [label="Export\<\"KnowledgeGraph\"\>\nThe full graph: nodes, edges, and metadata.\n📁 packages/tskb/src/core/graph/types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
