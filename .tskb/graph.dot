digraph KnowledgeGraph {
  rankdir=TB;
  compound=true;
  node [fontname="Arial", fontsize=10];
  edge [fontname="Arial", fontsize=8];

  subgraph "cluster___TSKB_ROOT__" {
    label="__TSKB.ROOT__";
    style=filled;
    fillcolor="#E3F2FD";
    color="#1976D2";

    "__TSKB.ROOT__" [label="Folder\<\"__TSKB.ROOT__\"\>\nThe root directory (automatically added by tskb)\n📁 .", shape=box, fillcolor="#BBDEFB", style=filled];

    subgraph "cluster_docs" {
      label="docs";
      style=filled;
      fillcolor="#E3F2FD";
      color="#1976D2";

      "docs" [label="Folder\<\"docs\"\>\nA folder that contains all the repo docs (.tskb.tsx) files. Uses its own ts configuration.\n📁 docs", shape=box, fillcolor="#BBDEFB", style=filled];

      // Modules in docs
      "sample.tsconfig.json" [label="Module\<\"sample.tsconfig.json\"\>\nAn example of required tsconfig.json for building <TSKB> docs\n📁 docs/tsconfig.json", shape=ellipse, fillcolor="#FFF9C4", style=filled];

    }

    subgraph "cluster_packages" {
      label="packages";
      style=filled;
      fillcolor="#E3F2FD";
      color="#1976D2";

      "packages" [label="Folder\<\"packages\"\>\nA folder that contains independent packages in the repo (npm worskspace)\n📁 packages", shape=box, fillcolor="#BBDEFB", style=filled];

      subgraph "cluster_TSKB_Package_Root" {
        label="TSKB.Package.Root";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1976D2";

        "TSKB.Package.Root" [label="Folder\<\"TSKB.Package.Root\"\>\nThe root folder of the package, with its package.json and main npm README.md\n📁 packages/tskb", shape=box, fillcolor="#BBDEFB", style=filled];

        // Modules in TSKB.Package.Root
        "package.json" [label="Module\<\"package.json\"\>\nLibrary's package.json file\n📁 packages/tskb/package.json", shape=ellipse, fillcolor="#FFF9C4", style=filled];
        "Main.index.js" [label="Module\<\"Main.index.js\"\>\nThe main package export\n📁 packages/tskb/src/index.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
          "ref" [label="Export\<\"ref\"\>\nA placeholder for referencing anything from the global tskb registry into jsx documentation tags\n📁 packages/tskb/src/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        subgraph "cluster_tskb_cli" {
          label="tskb.cli";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "tskb.cli" [label="Folder\<\"tskb.cli\"\>\nThe command-line interface.\n📁 packages/tskb/src/cli", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in tskb.cli
          "cli.index" [label="Module\<\"cli.index\"\>\nCLI entry point. Routes arguments to a command.\n📁 packages/tskb/src/cli/index.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          subgraph "cluster_tskb_cli_commands" {
            label="tskb.cli.commands";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.cli.commands" [label="Folder\<\"tskb.cli.commands\"\>\nOne file per CLI command.\n📁 packages/tskb/src/cli/commands", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.cli.commands
            "cli.commands.explore" [label="Module\<\"cli.commands.explore\"\>\nThe `tskb explore` command.\n📁 packages/tskb/src/cli/commands/explore.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.explore" [label="Export\<\"explorer.explore\"\>\nRuns the `tskb explore` command — serves the SPA, or exports it as static files with `--export`.\n📁 packages/tskb/src/cli/commands/explore.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.build" [label="Module\<\"cli.commands.build\"\>\nThe `tskb build` command.\n📁 packages/tskb/src/cli/commands/build.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.build" [label="Export\<\"cli.build\"\>\nBuilds the knowledge graph from .tskb.tsx sources.\n📁 packages/tskb/src/cli/commands/build.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.build.ExtractConfig" [label="Export\<\"cli.build.ExtractConfig\"\>\nConfig the build command takes: glob pattern and tsconfig path.\n📁 packages/tskb/src/cli/commands/build.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.search" [label="Module\<\"cli.commands.search\"\>\nThe `tskb search` command.\n📁 packages/tskb/src/cli/commands/search.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.search" [label="Export\<\"cli.search\"\>\nSearches the graph and returns ranked matches.\n📁 packages/tskb/src/cli/commands/search.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.pick" [label="Module\<\"cli.commands.pick\"\>\nThe `tskb pick` command.\n📁 packages/tskb/src/cli/commands/pick.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.pick" [label="Export\<\"cli.pick\"\>\nReturns full details for one node, by ID or path.\n📁 packages/tskb/src/cli/commands/pick.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.ls" [label="Module\<\"cli.commands.ls\"\>\nThe `tskb ls` command.\n📁 packages/tskb/src/cli/commands/ls.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.ls" [label="Export\<\"cli.ls\"\>\nLists folders in the graph as a hierarchy.\n📁 packages/tskb/src/cli/commands/ls.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.init" [label="Module\<\"cli.commands.init\"\>\nThe `tskb init` command. Scaffolds a new docs folder.\n📁 packages/tskb/src/cli/commands/init.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.commands.flows" [label="Module\<\"cli.commands.flows\"\>\nThe `tskb flows` command.\n📁 packages/tskb/src/cli/commands/flows.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          }

          subgraph "cluster_tskb_cli_utils" {
            label="tskb.cli.utils";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.cli.utils" [label="Folder\<\"tskb.cli.utils\"\>\nShared helpers for CLI commands.\n📁 packages/tskb/src/cli/utils", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.cli.utils
            "cli.utils.content-builder" [label="Module\<\"cli.utils.content-builder\"\>\nShared markdown content for the generated skill and instructions files.\n📁 packages/tskb/src/cli/utils/content-builder.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.skill-generator" [label="Module\<\"cli.utils.skill-generator\"\>\nWrites the Claude Code skill files for tskb.\n📁 packages/tskb/src/cli/utils/skill-generator.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.copilot-instructions" [label="Module\<\"cli.utils.copilot-instructions\"\>\nWrites the Copilot instructions files for tskb.\n📁 packages/tskb/src/cli/utils/copilot-instructions-generator.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.graph-finder" [label="Module\<\"cli.utils.graph-finder\"\>\nFinds the `.tskb/graph.json` file for the current project.\n📁 packages/tskb/src/cli/utils/graph-finder.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.logger" [label="Module\<\"cli.utils.logger\"\>\nLogger for CLI output.\n📁 packages/tskb/src/cli/utils/logger.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.resolve-node" [label="Module\<\"cli.utils.resolve-node\"\>\nResolves an identifier (ID or path) to a graph node and helps walk its edges.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.utils.resolve-node.resolveNode" [label="Export\<\"cli.utils.resolve-node.resolveNode\"\>\nResolves an ID or path to a node in the graph.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.getNodeEdges" [label="Export\<\"cli.utils.resolve-node.getNodeEdges\"\>\nReturns a node's incoming and outgoing edges.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findReferencingDocs" [label="Export\<\"cli.utils.resolve-node.findReferencingDocs\"\>\nReturns the docs that reference a given node.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findParent" [label="Export\<\"cli.utils.resolve-node.findParent\"\>\nReturns the parent folder or module of a node.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findAllNodesById" [label="Export\<\"cli.utils.resolve-node.findAllNodesById\"\>\nFinds every node sharing the same ID across types.\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];

          }

        }

        subgraph "cluster_tskb_core" {
          label="tskb.core";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "tskb.core" [label="Folder\<\"tskb.core\"\>\nCore build logic: registry extraction, doc extraction, graph assembly.\n📁 packages/tskb/src/core", shape=box, fillcolor="#BBDEFB", style=filled];

          subgraph "cluster_tskb_explorer_core" {
            label="tskb.explorer.core";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.explorer.core" [label="Folder\<\"tskb.explorer.core\"\>\nServer side of the explorer: turns the graph into chunks and serves them.\n📁 packages/tskb/src/core/explorer", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.core
            "explorer.transform" [label="Module\<\"explorer.transform\"\>\nTurns the graph into chunks the SPA can load.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.transformGraph" [label="Export\<\"explorer.transformGraph\"\>\nBuilds the explorer chunks from the graph.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "explorer.sanitizeFolderId" [label="Export\<\"explorer.sanitizeFolderId\"\>\nTurns a folder id into a safe chunk file name.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.server" [label="Module\<\"explorer.server\"\>\nHTTP server for the explorer. Serves the SPA and the chunk API.\n📁 packages/tskb/src/core/explorer/server.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.serveExplorer" [label="Export\<\"explorer.serveExplorer\"\>\nStarts the explorer HTTP server.\n📁 packages/tskb/src/core/explorer/server.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.export" [label="Module\<\"explorer.export\"\>\nWrites the explorer as a self-contained static folder.\n📁 packages/tskb/src/core/explorer/export.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.exportExplorer" [label="Export\<\"explorer.exportExplorer\"\>\nExports the explorer to a folder that opens from the file system.\n📁 packages/tskb/src/core/explorer/export.ts", shape=component, fillcolor="#C5E1A5", style=filled];

