            "core.extraction" [label="Folder\<\"core.extraction\"\>\nReads registry and docs out of TypeScript source.\n📁 packages/tskb/src/core/extraction", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in core.extraction
            "extraction.registry" [label="Module\<\"extraction.registry\"\>\nReads Folders, Modules, Exports, and Terms from the registry types.\n📁 packages/tskb/src/core/extraction/registry.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "extractRegistry" [label="Export\<\"extractRegistry\"\>\nExtracts the registry from TypeScript types.\n📁 packages/tskb/src/core/extraction/registry.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "ExtractedRegistry" [label="Export\<\"ExtractedRegistry\"\>\nThe registry data after extraction.\n📁 packages/tskb/src/core/extraction/registry.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "extraction.module-morphology" [label="Module\<\"extraction.module-morphology\"\>\nReads each module's exports and imports, with type stubs.\n📁 packages/tskb/src/core/extraction/module-morphology.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "extractModuleMorphology" [label="Export\<\"extractModuleMorphology\"\>\nExtracts a module's public exports and renders short code stubs for them.\n📁 packages/tskb/src/core/extraction/module-morphology.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "extractModuleImports" [label="Export\<\"extractModuleImports\"\>\nExtracts a module's import statements.\n📁 packages/tskb/src/core/extraction/module-morphology.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "extraction.documentation" [label="Module\<\"extraction.documentation\"\>\nReads `.tskb.tsx` files and extracts their content, references, relations, and flows.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "extractDocs" [label="Export\<\"extractDocs\"\>\nExtracts every `.tskb.tsx` file matched by the glob.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "ExtractedDoc" [label="Export\<\"ExtractedDoc\"\>\nThe data extracted from one doc file.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "extractFromTsxFile" [label="Export\<\"extractFromTsxFile\"\>\nExtracts one `.tskb.tsx` file.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "buildRefMap" [label="Export\<\"buildRefMap\"\>\nMaps each `const` in a doc file to the registry node it points to.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "JsxExtractor" [label="Export\<\"JsxExtractor\"\>\nWalks the JSX tree of a doc file and collects content, refs, relations, and flows.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "buildRefLink" [label="Export\<\"buildRefLink\"\>\nBuilds the HTML anchor for one inline reference.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "resolveNodeMeta" [label="Export\<\"resolveNodeMeta\"\>\nLooks up a node id in the registry and returns its type and display name.\n📁 packages/tskb/src/core/extraction/documentation/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];

