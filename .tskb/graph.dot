    "docs/src/tskb/explorer/explorer.tskb.tsx" [label="docs/src/tskb/explorer/explorer.tskb.tsx\nExplorer The explorer is a D3-powered SPA that renders the knowledge graph as a visual, interactive\n...\n📄 docs/src/tskb/explorer/explorer.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
    "docs/src/tskb/explorer/app.tskb.tsx" [label="docs/src/tskb/explorer/app.tskb.tsx\nExplorerApp in is the single top-level controller for the explorer SPA.\n      All canvas layers, UI ...\n📄 docs/src/tskb/explorer/app.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
    "docs/src/tskb/core/visualization.tskb.tsx" [label="docs/src/tskb/core/visualization.tskb.tsx\nVisualization Located in . Contains which provides . Transforms\n      a KnowledgeGraph into Graphviz...\n📄 docs/src/tskb/core/visualization.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
    "docs/src/tskb/core/registry-extraction.tskb.tsx" [label="docs/src/tskb/core/registry-extraction.tskb.tsx\nRegistry Extraction walks the TypeScript AST for registry declarations, then enriches each\n      mod...\n📄 docs/src/tskb/core/registry-extraction.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
    "docs/src/tskb/core/graph-builder.tskb.tsx" [label="docs/src/tskb/core/graph-builder.tskb.tsx\nGraph Module Located in . Takes extracted registry and documentation, produces a   . Modules : Defin...\n📄 docs/src/tskb/core/graph-builder.tskb.tsx", shape=note, fillcolor="#E1BEE7", style=filled];
