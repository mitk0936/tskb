        }

        subgraph "cluster_Pages" {
          label="Pages";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Pages" [label="Folder\<\"Pages\"\>\nTop-level page components mapped to routes\n📁 examples/taskflow-app/src/client/pages", shape=box, fillcolor="#BBDEFB", style=filled];

        }

        subgraph "cluster_Contexts" {
          label="Contexts";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Contexts" [label="Folder\<\"Contexts\"\>\nReact Context providers for global state management\n📁 examples/taskflow-app/src/client/contexts", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in Contexts
          "AuthContext" [label="Module\<\"AuthContext\"\>\nReact Context providing authentication state and login/logout methods\n📁 examples/taskflow-app/src/client/contexts/AuthContext.tsx", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          // Exports in Contexts
          "TaskContext" [label="Export\<\"TaskContext\"\>\nReact Context managing task state and CRUD operations\n📁 examples/taskflow-app/src/client/contexts/TaskContext.tsx", shape=component, fillcolor="#C5E1A5", style=filled];
          "ProjectContext" [label="Export\<\"ProjectContext\"\>\nReact Context for project selection and management\n📁 examples/taskflow-app/src/client/contexts/ProjectContext.tsx", shape=component, fillcolor="#C5E1A5", style=filled];

        }

        subgraph "cluster_Hooks" {
          label="Hooks";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Hooks" [label="Folder\<\"Hooks\"\>\nCustom React hooks for shared logic\n📁 examples/taskflow-app/src/client/hooks", shape=box, fillcolor="#BBDEFB", style=filled];

        }

        subgraph "cluster_ClientServices" {
          label="ClientServices";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "ClientServices" [label="Folder\<\"ClientServices\"\>\nAPI client services for backend communication\n📁 examples/taskflow-app/src/client/services", shape=box, fillcolor="#BBDEFB", style=filled];

          // Exports in ClientServices
          "WebSocketService" [label="Export\<\"WebSocketService\"\>\nReal-time communication service for live updates\n📁 examples/taskflow-app/src/client/services/websocket.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "ApiClient" [label="Export\<\"ApiClient\"\>\nBase HTTP client for API communication with authentication\n📁 examples/taskflow-app/src/client/services/api.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        }

      }

      subgraph "cluster_Server" {
        label="Server";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1976D2";

        "Server" [label="Folder\<\"Server\"\>\nNode.js backend API with services, controllers, and middleware\n📁 examples/taskflow-app/src/server", shape=box, fillcolor="#BBDEFB", style=filled];

        subgraph "cluster_Services" {
          label="Services";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Services" [label="Folder\<\"Services\"\>\nBusiness logic layer handling core application operations\n📁 examples/taskflow-app/src/server/services", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in Services
          "AuthService" [label="Module\<\"AuthService\"\>\nHandles user authentication, registration, and token management\n📁 examples/taskflow-app/src/server/services/auth.service.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          // Exports in Services
          "TaskService" [label="Export\<\"TaskService\"\>\nManages task CRUD operations, status updates, and assignments\n📁 examples/taskflow-app/src/server/services/task.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "ProjectService" [label="Export\<\"ProjectService\"\>\nHandles project lifecycle, team assignments, and member management\n📁 examples/taskflow-app/src/server/services/project.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "UserService" [label="Export\<\"UserService\"\>\nManages user profiles and team memberships\n📁 examples/taskflow-app/src/server/services/user.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "NotificationService" [label="Export\<\"NotificationService\"\>\nCreates and delivers notifications for task updates and mentions\n📁 examples/taskflow-app/src/server/services/notification.service.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        }

        subgraph "cluster_Controllers" {
          label="Controllers";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Controllers" [label="Folder\<\"Controllers\"\>\nHTTP request handlers that coordinate between routes and services\n📁 examples/taskflow-app/src/server/controllers", shape=box, fillcolor="#BBDEFB", style=filled];

        }

        subgraph "cluster_Middleware" {
          label="Middleware";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Middleware" [label="Folder\<\"Middleware\"\>\nExpress middleware for authentication, validation, and error handling\n📁 examples/taskflow-app/src/server/middleware", shape=box, fillcolor="#BBDEFB", style=filled];

          // Exports in Middleware
          "ErrorHandler" [label="Export\<\"ErrorHandler\"\>\nGlobal error handling middleware for consistent API responses\n📁 examples/taskflow-app/src/server/middleware/error.middleware.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "AuthMiddleware" [label="Export\<\"AuthMiddleware\"\>\nAuthentication and authorization middleware for protected routes\n📁 examples/taskflow-app/src/server/middleware/auth.middleware.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        }

        subgraph "cluster_Database" {
          label="Database";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Database" [label="Folder\<\"Database\"\>\nDatabase connection and repository layer for data persistence\n📁 examples/taskflow-app/src/server/database", shape=box, fillcolor="#BBDEFB", style=filled];

          // Exports in Database
          "Database" [label="Export\<\"Database\"\>\nDatabase connection manager with query execution and transaction support\n📁 examples/taskflow-app/src/server/database/connection.ts", shape=component, fillcolor="#C5E1A5", style=filled];

          subgraph "cluster_Repositories" {
            label="Repositories";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "Repositories" [label="Folder\<\"Repositories\"\>\nData access layer abstracting database operations\n📁 examples/taskflow-app/src/server/database/repositories", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in Repositories
            "TaskRepository" [label="Module\<\"TaskRepository\"\>\nData access layer for task persistence with pagination and filtering\n📁 examples/taskflow-app/src/server/database/repositories/task.repository.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

            // Exports in Repositories
            "UserRepository" [label="Export\<\"UserRepository\"\>\nData access layer for user CRUD operations\n📁 examples/taskflow-app/src/server/database/repositories/user.repository.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "ProjectRepository" [label="Export\<\"ProjectRepository\"\>\nData access layer for project data persistence\n📁 examples/taskflow-app/src/server/database/repositories/project.repository.ts", shape=component, fillcolor="#C5E1A5", style=filled];

          }

        }

      }

      subgraph "cluster_Shared" {
        label="Shared";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1976D2";

        "Shared" [label="Folder\<\"Shared\"\>\nShared TypeScript types and utilities used by both client and server\n📁 examples/taskflow-app/src/shared", shape=box, fillcolor="#BBDEFB", style=filled];

        subgraph "cluster_Types" {
          label="Types";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Types" [label="Folder\<\"Types\"\>\nTypeScript type definitions shared across the application\n📁 examples/taskflow-app/src/shared/types", shape=box, fillcolor="#BBDEFB", style=filled];

          // Exports in Types
          "Task" [label="Export\<\"Task\"\>\nTask entity type with status, priority, and assignment properties\n📁 examples/taskflow-app/src/shared/types/task.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "Project" [label="Export\<\"Project\"\>\nProject entity type with team and status information\n📁 examples/taskflow-app/src/shared/types/project.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "PaginationParams" [label="Export\<\"PaginationParams\"\>\nPagination parameters for list queries (page, limit, sorting)\n📁 examples/taskflow-app/src/shared/types/api.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "FilterParams" [label="Export\<\"FilterParams\"\>\nFilter parameters for querying tasks by status, priority, date range, etc.\n📁 examples/taskflow-app/src/shared/types/api.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "ApiResponse" [label="Export\<\"ApiResponse\"\>\nStandard API response wrapper with data, error, and metadata fields\n📁 examples/taskflow-app/src/shared/types/api.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "PaginatedResponse" [label="Export\<\"PaginatedResponse\"\>\nGeneric paginated response with items, total count, and page metadata\n📁 examples/taskflow-app/src/shared/types/api.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];
          "User" [label="Export\<\"User\"\>\nUser entity type with authentication and profile information\n📁 examples/taskflow-app/src/shared/types/user.types.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        }

        subgraph "cluster_Utils" {
          label="Utils";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Utils" [label="Folder\<\"Utils\"\>\nUtility functions for validation, formatting, and common operations\n📁 examples/taskflow-app/src/shared/utils", shape=box, fillcolor="#BBDEFB", style=filled];

        }

        subgraph "cluster_Config" {
          label="Config";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "Config" [label="Folder\<\"Config\"\>\nConfiguration constants and environment variables\n📁 examples/taskflow-app/src/shared/config", shape=box, fillcolor="#BBDEFB", style=filled];

        }

      }

    }

    subgraph "cluster_packages" {
      label="packages";
      style=filled;
      fillcolor="#E3F2FD";
      color="#1976D2";

      "packages" [label="Folder\<\"packages\"\>\nA folder that contains independent packages in the repo (npm worskspace)\n📁 packages", shape=box, fillcolor="#BBDEFB", style=filled];

      subgraph "cluster_TSKB_Package_Root" {
        label="TSKB.Package.Root";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1976D2";

        "TSKB.Package.Root" [label="Folder\<\"TSKB.Package.Root\"\>\nThe root folder of the package, with its package.json and main npm README.md\n📁 packages/tskb", shape=box, fillcolor="#BBDEFB", style=filled];

        // Modules in TSKB.Package.Root
        "package.json" [label="Module\<\"package.json\"\>\nLibrary's package.json file\n📁 packages/tskb/package.json", shape=ellipse, fillcolor="#FFF9C4", style=filled];
        "Main.index.js" [label="Module\<\"Main.index.js\"\>\nThe main package export\n📁 packages/tskb/src/index.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
          "ref" [label="Export\<\"ref\"\>\nA placeholder for referencing anything from the global tskb registry into jsx documentation tags\n📁 packages/tskb/src/index.ts", shape=component, fillcolor="#C5E1A5", style=filled];

        subgraph "cluster_tskb_cli" {
          label="tskb.cli";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "tskb.cli" [label="Folder\<\"tskb.cli\"\>\nSource code for the cli\n📁 packages/tskb/src/cli", shape=box, fillcolor="#BBDEFB", style=filled];

          // Modules in tskb.cli
          "cli.index" [label="Module\<\"cli.index\"\>\nCLI entry point - handles argument parsing, command routing, and error handling\n📁 packages/tskb/src/cli/index.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          subgraph "cluster_tskb_cli_commands" {
            label="tskb.cli.commands";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.cli.commands" [label="Folder\<\"tskb.cli.commands\"\>\nCommand implementations for init, build, search, pick, context, ls, and docs\n📁 packages/tskb/src/cli/commands", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.cli.commands
            "cli.commands.explore" [label="Module\<\"cli.commands.explore\"\>\nEntry point for `tskb explore`: loads graph.json, then either serves locally or exports static files depending on --export flag\n📁 packages/tskb/src/cli/commands/explore.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.explore" [label="Export\<\"explorer.explore\"\>\nCLI command handler: finds graph.json via graph-finder, branches to serveExplorer or exportExplorer based on --export flag\n📁 packages/tskb/src/cli/commands/explore.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.build" [label="Module\<\"cli.commands.build\"\>\nBuild command module - orchestrates the complete pipeline from source files to knowledge graph, DOT visualization, and agent guidance\n📁 packages/tskb/src/cli/commands/build.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.build" [label="Export\<\"cli.build\"\>\nThe control flow function for the cli, building the docs, graph, and visualization outputing to the .tskb/ directory\n📁 packages/tskb/src/cli/commands/build.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.build.ExtractConfig" [label="Export\<\"cli.build.ExtractConfig\"\>\nConfiguration interface for the build command containing glob pattern and tsconfig path\n📁 packages/tskb/src/cli/commands/build.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.search" [label="Module\<\"cli.commands.search\"\>\nSearch command module - fuzzy searches the entire knowledge graph for nodes matching a query, returning ranked results\n📁 packages/tskb/src/cli/commands/search.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.search" [label="Export\<\"cli.search\"\>\nFuzzy searches the entire knowledge graph for nodes matching a query, returning ranked results with scores across IDs, descriptions, and paths\n📁 packages/tskb/src/cli/commands/search.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.pick" [label="Module\<\"cli.commands.pick\"\>\nPick command module - resolves any node by ID or filesystem path, returning type-specific data for folders, modules, exports, terms, and docs\n📁 packages/tskb/src/cli/commands/pick.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.pick" [label="Export\<\"cli.pick\"\>\nResolves any node by ID or filesystem path, returning type-specific data for folders, modules, exports, terms, and docs\n📁 packages/tskb/src/cli/commands/pick.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.ls" [label="Module\<\"cli.commands.ls\"\>\nList command module - recursively lists all folders from root with controllable depth, returning flat JSON hierarchy\n📁 packages/tskb/src/cli/commands/ls.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.ls" [label="Export\<\"cli.ls\"\>\nLists all folders in the knowledge graph from TSKB.Package.Root with controllable depth, returning flat JSON hierarchy\n📁 packages/tskb/src/cli/commands/ls.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "cli.commands.init" [label="Module\<\"cli.commands.init\"\>\nInit command module - interactive scaffolder that creates docs folder, tsconfig, starter doc, build script, and AI integration directories\n📁 packages/tskb/src/cli/commands/init.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.commands.flows" [label="Module\<\"cli.commands.flows\"\>\nFlows command module - lists all flows sorted by priority, with optional fuzzy search\n📁 packages/tskb/src/cli/commands/flows.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];

          }

          subgraph "cluster_tskb_cli_utils" {
            label="tskb.cli.utils";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.cli.utils" [label="Folder\<\"tskb.cli.utils\"\>\nCLI utilities - output generators (skill, copilot instructions), shared content builder, graph file finder\n📁 packages/tskb/src/cli/utils", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.cli.utils
            "cli.utils.content-builder" [label="Module\<\"cli.utils.content-builder\"\>\nShared markdown content builder - produces query body and update body (syntax + session triggers) for generated skill/instructions files\n📁 packages/tskb/src/cli/utils/content-builder.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.skill-generator" [label="Module\<\"cli.utils.skill-generator\"\>\nGenerates two Claude Code skills: tskb (query/explore) and tskb-update (write & update docs)\n📁 packages/tskb/src/cli/utils/skill-generator.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.copilot-instructions" [label="Module\<\"cli.utils.copilot-instructions\"\>\nGenerates two Copilot instructions files: tskb (query/explore) and tskb-update (write & update docs)\n📁 packages/tskb/src/cli/utils/copilot-instructions-generator.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.graph-finder" [label="Module\<\"cli.utils.graph-finder\"\>\nLocates .tskb/graph.json from the current working directory, used by search/pick/ls commands\n📁 packages/tskb/src/cli/utils/graph-finder.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.logger" [label="Module\<\"cli.utils.logger\"\>\nCLI logger — all output to stderr, supports verbosity levels and timing. Configured once at startup via configure({ verbose })\n📁 packages/tskb/src/cli/utils/logger.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
            "cli.utils.resolve-node" [label="Module\<\"cli.utils.resolve-node\"\>\nNode resolution utility — resolves any identifier (ID or path) to a graph node, and provides edge helpers for finding parents, referencing docs, and splitting incoming/outgoing edges\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "cli.utils.resolve-node.resolveNode" [label="Export\<\"cli.utils.resolve-node.resolveNode\"\>\nThree-step resolution: exact ID match → path match → nearest parent folder. Returns ResolvedNode with the matched node and which strategy succeeded, or null\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.getNodeEdges" [label="Export\<\"cli.utils.resolve-node.getNodeEdges\"\>\nSplits all graph edges into incoming and outgoing arrays for a given node ID\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findReferencingDocs" [label="Export\<\"cli.utils.resolve-node.findReferencingDocs\"\>\nReturns DocRef array of doc nodes that reference a given node via 'references' edges\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findParent" [label="Export\<\"cli.utils.resolve-node.findParent\"\>\nFinds the parent folder or module of a node by traversing 'belongs-to' (outgoing) or 'contains' (incoming) edges\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "cli.utils.resolve-node.findAllNodesById" [label="Export\<\"cli.utils.resolve-node.findAllNodesById\"\>\nFinds all nodes matching an ID across every type dictionary — returns multiple matches when different types share the same ID\n📁 packages/tskb/src/cli/utils/resolve-node.ts", shape=component, fillcolor="#C5E1A5", style=filled];

          }

        }

        subgraph "cluster_tskb_core" {
          label="tskb.core";
          style=filled;
          fillcolor="#E3F2FD";
          color="#1976D2";

          "tskb.core" [label="Folder\<\"tskb.core\"\>\nSource code for the core - extraction logic for registry (TS interfaces used as a registry) and 'doc' processing <Doc>...</Doc>\n📁 packages/tskb/src/core", shape=box, fillcolor="#BBDEFB", style=filled];

          subgraph "cluster_tskb_explorer_core" {
            label="tskb.explorer.core";
            style=filled;
            fillcolor="#E3F2FD";
            color="#1976D2";

            "tskb.explorer.core" [label="Folder\<\"tskb.explorer.core\"\>\nCLI-side explorer layer: graph→chunk transform, HTTP server, and static export\n📁 packages/tskb/src/core/explorer", shape=box, fillcolor="#BBDEFB", style=filled];

            // Modules in tskb.explorer.core
            "explorer.transform" [label="Module\<\"explorer.transform\"\>\nConverts KnowledgeGraph into ExplorerChunks: a MetaChunk (root, topFolders, docs, flows, terms, externals) plus one FolderChunk per folder that has modules or sub-folders. Two ghost injection passes: buildGhostIntermediaryChains() synthesizes FolderChunks for every filesystem directory that lies between a declared folder's path and its owned modules/subfolders; injectGhostNodes() adds ghost ExplorerNodes for any .ts/.tsx files recorded in folder.children.files that are not declared as modules.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.transformGraph" [label="Export\<\"explorer.transformGraph\"\>\nEntry point: builds edge lookup indexes, assembles MetaChunk, recurses into all folders to build FolderChunks, synthesizes ghost intermediary chunks for path-gap directories, injects ghost nodes from scanner data, then patches _hasChildren / _childCount on every folder node.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=component, fillcolor="#C5E1A5", style=filled];
              "explorer.sanitizeFolderId" [label="Export\<\"explorer.sanitizeFolderId\"\>\nConverts an arbitrary folder id into a filename-safe string (replaces non-alphanumeric chars with underscores). Used by both server and export to derive chunk file names.\n📁 packages/tskb/src/core/explorer/transform.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.server" [label="Module\<\"explorer.server\"\>\nNode built-in HTTP server that serves the pre-built SPA assets and generates chunk JSON responses on demand. Reads graph.json once, transforms it, and caches all chunk JSON strings in memory for the lifetime of the process.\n📁 packages/tskb/src/core/explorer/server.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
              "explorer.serveExplorer" [label="Export\<\"explorer.serveExplorer\"\>\nStarts a Node http server that serves the pre-built SPA + chunk API. Resolves SPA assets via import.meta.url so it works after npm pack. Optionally auto-opens the browser.\n📁 packages/tskb/src/core/explorer/server.ts", shape=component, fillcolor="#C5E1A5", style=filled];
            "explorer.export" [label="Module\<\"explorer.export\"\>\nCopies pre-built SPA assets to an output directory and writes all chunk JSON files alongside them, producing a fully self-contained static explorer that works offline via file://\n📁 packages/tskb/src/core/explorer/export.ts", shape=ellipse, fillcolor="#FFF9C4", style=filled];
