              "explorer.spa.GraphStore" [label="Export\<\"explorer.spa.GraphStore\"\>\nPure data store holding meta chunk and folder chunks. Exposes subscribe(listener) for reactive re-render; UI state lives outside in main.ts.\n📁 packages/tskb/explorer-app/src/store/graph-store.ts", shape=component, fillcolor="#C5E1A5", style=filled];

